{
  "info": {
    "name": "SuitPay API Smoke Tests",
    "_postman_id": "suitpay-api-smoke-v1",
    "description": "Coleção de smoke tests para a API do ambiente sandbox da SuitPay.\nFrontend: web.sandbox.suitpay.app\nAPI Backend: sandbox.ws.suitpay.app/api/v1\nExecutada via Newman no pipeline de CI/CD.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check — Página de Login (Frontend)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://web.sandbox.suitpay.app/login",
          "protocol": "https",
          "host": ["web", "sandbox", "suitpay", "app"],
          "path": ["login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Frontend acessível — status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Resposta recebida em menos de 5s', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth — Login com credenciais inválidas (rejeita acesso)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"invalid@smoke.test\",\n  \"password\": \"invalid_password\"\n}"
        },
        "url": {
          "raw": "https://sandbox.ws.suitpay.app/api/v1/auth/signin",
          "protocol": "https",
          "host": ["sandbox", "ws", "suitpay", "app"],
          "path": ["api", "v1", "auth", "signin"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Endpoint de login rejeita credenciais inválidas (não retorna 2xx)', function () {",
              "  pm.expect(pm.response.code).to.be.at.least(400);",
              "});",
              "",
              "pm.test('Resposta recebida em menos de 5s', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
