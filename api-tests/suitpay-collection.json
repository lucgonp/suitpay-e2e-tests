{
  "info": {
    "name": "SuitPay API Smoke Tests",
    "_postman_id": "suitpay-api-smoke-v1",
    "description": "Coleção de smoke tests para a API do ambiente sandbox da SuitPay.\nFrontend: web.sandbox.suitpay.app\nAPI Backend: sandbox.ws.suitpay.app/api/v1\nExecutada via Newman no pipeline de CI/CD.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check — Página de Login (Frontend)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{FRONTEND_URL}}/login"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Frontend acessível — status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Resposta recebida em menos de 5s', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth — Login com credenciais inválidas (espera 401)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"invalid@smoke.test\",\n  \"password\": \"invalid_password\"\n}"
        },
        "url": {
          "raw": "{{API_URL}}/api/v1/auth/signin"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Endpoint de login responde com 401 para credenciais inválidas', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Resposta recebida em menos de 5s', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});",
              "",
              "pm.test('Corpo da resposta indica erro de credencial', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('status', 401);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "FRONTEND_URL",
      "value": "https://web.sandbox.suitpay.app",
      "description": "URL do frontend React. Sobrescrito via --env-var no CI."
    },
    {
      "key": "API_URL",
      "value": "https://sandbox.ws.suitpay.app",
      "description": "URL base da API REST. Sobrescrito via --env-var no CI."
    }
  ]
}
